+  /**
+   * Delete one or more actors from the world directory.
+   * PERMANENT — Foundry has no undo. Gated by the HIGH_RISK `deleteData`
+   * permission (GM + allowWriteOperations). Unmatched ids are reported in
+   * failedActors rather than throwing, so a bad id never cascades into a wipe.
+   */
+  async deleteActors(data: { actorIds: string[] }): Promise<any> {
+    this.validateFoundryState();
+
+    const permissionCheck = permissionManager.checkWritePermission('deleteData', {
+      targetIds: data.actorIds,
+    });
+
+    if (!permissionCheck.allowed) {
+      throw new Error(`${ERROR_MESSAGES.ACCESS_DENIED}: ${permissionCheck.reason}`);
+    }
+
+    try {
+      const deletedActors: string[] = [];
+      const failedActors: string[] = [];
+
+      for (const actorId of data.actorIds) {
+        try {
+          const actor = (game.actors as any)?.get(actorId);
+          if (actor) {
+            await actor.delete();
+            deletedActors.push(actorId);
+          } else {
+            failedActors.push(actorId);
+          }
+        } catch (error) {
+          failedActors.push(actorId);
+        }
+      }
+
+      this.auditLog(
+        'deleteActors',
+        { actorIds: data.actorIds, deletedCount: deletedActors.length },
+        'success'
+      );
+
+      return {
+        success: true,
+        deletedCount: deletedActors.length,
+        deletedActors,
+        failedActors: failedActors.length > 0 ? failedActors : undefined,
+      };
+    } catch (error) {
+      this.auditLog(
+        'deleteActors',
+        data,
+        'failure',
+        error instanceof Error ? error.message : 'Unknown error'
+      );
+      throw new Error(
+        `Failed to delete actors: ${error instanceof Error ? error.message : 'Unknown error'}`
+      );
+    }
+  }
+
