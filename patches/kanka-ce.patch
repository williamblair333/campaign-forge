diff --git a/app/Services/DomainService.php b/app/Services/DomainService.php
index c7d585706..af0147dbd 100644
--- a/app/Services/DomainService.php
+++ b/app/Services/DomainService.php
@@ -21,7 +21,11 @@ public function isApp(): bool
      */
     public function isApi(): bool
     {
-        return $this->request->is('api/*') || $this->request->host() === $this->api();
+        // Only use host-based detection. The path-based fallback (`is('api/*')`)
+        // breaks single-domain local installs: when a request arrives at /api/*,
+        // isApi() returns true, routes get registered under the API subdomain with
+        // no /api prefix, and the same request never matches them.
+        return $this->request->host() === $this->api();
     }
 
