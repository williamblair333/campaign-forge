# campaign-forge environment configuration
# Copy this file to .env and fill in your values.

# Base URL where Kanka CE is running
KANKA_BASE_URL=http://localhost:8081

# Your Kanka CE API token
# Generate at: http://localhost:8081 → Settings → API → Create token
# Or via: vendor/bin/sail artisan tinker (see SETUP.md)
KANKA_TOKEN=your-token-here

# The campaign ID to use as default when not specified
# After setup, campaign id=1 is the first campaign you create
KANKA_CAMPAIGN_ID=1
